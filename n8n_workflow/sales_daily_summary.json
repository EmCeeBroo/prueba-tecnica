{
  "name": "Sales Daily Summary",
  "nodes": [
    {
      "parameters": {
        "rule": { "interval": [{ "hours": 24 }] }
      },
      "id": "cron-trigger",
      "name": "Ejecutar diariamente",
      "type": "n8n-nodes-base.cron",
      "position": [250, 300]
    },
    {
      "parameters": {
        "url": "http://api:8000/jobs/completed",
        "method": "GET"
      },
      "id": "http-request",
      "name": "Obtener jobs completados",
      "type": "n8n-nodes-base.httpRequest",
      "position": [450, 300]
    },
    {
      "parameters": {
        "query": "SELECT date::date, SUM(total) as total_sales FROM sales WHERE date >= CURRENT_DATE - INTERVAL '30 days' GROUP BY date::date ORDER BY date DESC"
      },
      "id": "postgres-query",
      "name": "Calcular ventas por día",
      "type": "n8n-nodes-base.postgres",
      "position": [650, 300],
      "credentials": {
        "postgres": {
          "id": "1",
          "name": "Postgres"
        }
      }
    },
    {
      "parameters": {
        "table": "sales_daily_summary",
        "columns": "date, total_sales",
        "insertMethod": "onConflictMerge"
      },
      "id": "postgres-insert",
      "name": "Guardar resumen",
      "type": "n8n-nodes-base.postgres",
      "position": [850, 300],
      "credentials": {
        "postgres": {
          "id": "1",
          "name": "Postgres"
        }
      }
    }
  ],
  "connections": {
    "Ejecutar diariamente": {
      "main": [[{"node": "Obtener jobs completados", "type": "main", "index": 0}]]
    },
    "Obtener jobs completados": {
      "main": [[{"node": "Calcular ventas por día", "type": "main", "index": 0}]]
    },
    "Calcular ventas por día": {
      "main": [[{"node": "Guardar resumen", "type": "main", "index": 0}]]
    }
  }
}